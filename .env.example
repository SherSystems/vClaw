# ============================================================
# RHODES — Operator configuration
# Tagline: Infrastructure, executed.
# ============================================================
# This file is the authoritative example. Copy to .env at the
# install root (e.g. /opt/rhodes/.env) and fill in real values.
# ============================================================

# Proxmox VE Connection
PROXMOX_HOST=192.168.1.100
PROXMOX_PORT=8006
PROXMOX_TOKEN_ID=root@pam!rhodes
PROXMOX_TOKEN_SECRET=your-token-secret-here
PROXMOX_ALLOW_SELF_SIGNED=true

# VMware vSphere Connection
VMWARE_HOST=vcenter.lab.local
VMWARE_USER=administrator@vsphere.local
VMWARE_PASSWORD=your-password-here
VMWARE_INSECURE=true

# Azure Connection (Service Principal)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_DEFAULT_LOCATION=eastus

# AWS Connection (IAM user or role credentials)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
AWS_SESSION_TOKEN=

# System Adapter (SSH behavior)
# true  = verify host keys (recommended/default)
# false = skip host key checks (legacy/insecure behavior)
SYSTEM_SSH_STRICT_HOST_KEY_CHECK=true

# AI / LLM Configuration
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-api03-your-key-here
AI_MODEL=claude-haiku-4-5-20251001

# Web Dashboard
DASHBOARD_PORT=3000

# Autopilot
AUTOPILOT_ENABLED=false
AUTOPILOT_POLL_INTERVAL_MS=30000

# Executor Reliability
EXECUTOR_MAX_RETRIES=2
EXECUTOR_RETRY_BASE_BACKOFF_MS=250
EXECUTOR_RETRY_MAX_BACKOFF_MS=4000
EXECUTOR_RETRY_JITTER_RATIO=0.2
EXECUTOR_RETRY_ON_TIMEOUT=true
EXECUTOR_MAX_TOOL_CALLS_PER_RUN=200
EXECUTOR_MAX_TOOL_CALLS_PER_PLAN=100

# Chaos Engineering
# Comma-separated VM IDs that chaos engineering must never target
# (e.g. the VM running RHODES itself)
CHAOS_PROTECTED_VMIDS=100

# ============================================================
# Deployment / Runtime
# ============================================================

# Free-form label included in telemetry and alerts. Useful when
# you run more than one RHODES instance (homelab, staging, prod).
RHODES_DEPLOYMENT_NAME=homelab

# Port that the /healthz endpoint binds to. Probed by systemd /
# external monitors. Must be free on the host.
RHODES_HEALTH_PORT=7411

# Autopilot dry-run flag. When true, the autopilot plans actions
# but does not execute them. Agent 3 reads this.
RHODES_DRY_RUN=false

# ============================================================
# Alerting
# ============================================================
# RHODES routes operator-facing alerts (autopilot decisions,
# unhealthy hosts, drift) through one of these providers.
#
#   supra            -> POST to your Supra AI instance, which fans
#                       out via its own notification graph.
#   telegram_direct  -> POST directly to the Telegram Bot API.
#   none             -> alerts logged only; no external delivery.
RHODES_ALERT_PROVIDER=supra

# Used when RHODES_ALERT_PROVIDER=supra
SUPRA_URL=http://localhost:3100

# Used when RHODES_ALERT_PROVIDER=telegram_direct
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Base URL of the RHODES dashboard, used to deep-link approval-pending
# Telegram messages directly to the matching plan card. When set, every
# awaiting_approval alert includes a line:
#     Approve at: <RHODES_DASHBOARD_URL>/?plan=<plan_id>
# The dashboard reads `?plan=<id>` on load and scrolls + highlights the
# matching card. Leave empty to suppress the link.
# Example for the NUC over Tailscale: http://100.73.129.96:7412
RHODES_DASHBOARD_URL=

# ============================================================
# Service-level Probes (in-VM HTTP health checks)
# ============================================================
# RHODES today watches Proxmox-level state (running/stopped/paused).
# Some services crash *inside* the VM while QEMU still reports the
# guest as `running`. The service-http-probe playbook closes that
# gap: periodic HTTP GET → SSH systemctl diagnostic → auto-restart
# at Tier 2 → verify. See src/playbooks/service-http-probe.ts.

# Jellyfin (the canonical example of an in-VM service probe)
JELLYFIN_PROBE_URL=http://100.105.89.123:8096/health
JELLYFIN_SSH_TARGET=pranav@100.105.89.123
JELLYFIN_PROBE_INTERVAL_SECS=60
JELLYFIN_PROBE_TIMEOUT_MS=5000
JELLYFIN_FAILURE_THRESHOLD=3
